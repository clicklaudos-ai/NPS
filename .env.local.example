# Copie este arquivo para ".env.local" e preencha com os dados do seu projeto Supabase
# (Supabase → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-public-aqui

# Disparo de NPS em massa por e-mail (resend.com)
# Crie uma conta gratuita em https://resend.com, gere uma API key em
# Dashboard -> API Keys, e cole abaixo. NÃO leve o prefixo NEXT_PUBLIC_
# porque essa chave é usada só no servidor (nunca fica exposta no navegador).
RESEND_API_KEY=re_sua_api_key_aqui
# E-mail remetente. Enquanto nenhum domínio próprio for verificado no Resend,
# use "onboarding@resend.dev" (só envia para o e-mail da sua conta Resend).
# Depois de verificar seu domínio em Resend -> Domains, troque para algo como
# "pesquisas@clicklaudos.com.br".
RESEND_FROM_EMAIL=onboarding@resend.dev
